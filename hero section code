<section class="custom-hero">

<div class="page-width hero-main">

<div class="hero-left">

<h1>{{ section.settings.heading }}</h1>

<p>{{ section.settings.subtext }}</p>

<a href="{{ section.settings.btn_link }}" class="hero-btn">
{{ section.settings.btn_text }}
</a>

</div>

<div class="hero-right">

<img src="{{ section.settings.hero_image | image_url }}" alt="">

</div>

</div>


<div class="hero-products">

{% for block in section.blocks %}

<div class="hero-product-card">

<img src="{{ block.settings.image | image_url }}">

<h4>{{ block.settings.title }}</h4>

<p>{{ block.settings.price }}</p>

</div>

{% endfor %}

</div>

</section>


{% schema %}
{
"name": "Custom Hero",
"settings":[
{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"Cutting Edge Beauty Tools"
},
{
"type":"textarea",
"id":"subtext",
"label":"Sub text",
"default":"Innovative, Sleek, Transformative Beauty Solutions."
},
{
"type":"image_picker",
"id":"hero_image",
"label":"Hero Image"
},
{
"type":"text",
"id":"btn_text",
"label":"Button Text",
"default":"Shop Now"
},
{
"type":"url",
"id":"btn_link",
"label":"Button Link"
}
],

"blocks":[
{
"type":"product",
"name":"Product Card",
"settings":[
{"type":"image_picker","id":"image","label":"Image"},
{"type":"text","id":"title","label":"Title"},
{"type":"text","id":"price","label":"Price"}
]
}
],

"max_blocks":4,
"presets":[
{
"name":"Custom Hero"
}
]
}
{% endschema %}
